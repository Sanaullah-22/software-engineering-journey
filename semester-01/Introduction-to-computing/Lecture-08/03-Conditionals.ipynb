    "#conditionals\n",
    "def absolute_value(x):\n",
    "    if x > 0:\n",
    "        return x\n",
    "    elif x == 0:\n",
    "        return (\"X is equal to zero\")\n",
    "    else:\n",
    "        return -x\n",
    "result =absolute_value(0)\n",
    "result =absolute_value(-60)\n",
    "result =absolute_value(5)\n",
    "print(result)"
   ]
